# ─── Inkwell environment template ───────────────────────────────────────
# Copy to .env.local and fill in (NEVER put real secrets in this file — it's committed to git).
# Next.js reads .env.local, not .env.example. Full walkthrough: docs/10-setup-guide.md.

# ════════════════ PHASE 1 — required to run the app ════════════════

# Database (PostgreSQL). Free: Neon (neon.tech) or Supabase.
# Example (Neon): postgresql://user:pass@ep-xxx.neon.tech/db?sslmode=require
DATABASE_URL=

# Auth.js session secret — REQUIRED. Generate with:  npx auth secret
AUTH_SECRET=

# OAuth (optional — email/password works without these)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ════════════════ PHASE 2 — generation pipeline ════════════════
# Runs at $0 with NO keys (mock provider). Add keys to upgrade the engines.

# Text brain (story / script / dialogue). Gemini's key also does images.
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Open-source / managed image fallbacks
FAL_KEY=
REPLICATE_API_TOKEN=

# Free real images via Cloudflare Workers AI (FLUX-schnell), no Gemini billing needed.
# dash.cloudflare.com → Workers AI → Account ID + an API token. docs/11-phase2-guide.md Option B.
CF_ACCOUNT_ID=
CF_API_TOKEN=
CF_IMAGE_MODEL=@cf/black-forest-labs/flux-1-schnell

# Optional providers
POLLINATIONS_TOKEN=
HIGGSFIELD_API_KEY=

# Asset storage (leave blank → data: URLs, zero-config). R2 for production.
ASSET_BUCKET_NAME=
ASSET_BUCKET_ENDPOINT=
ASSET_BUCKET_ACCESS_KEY=
ASSET_BUCKET_SECRET_KEY=
ASSET_PUBLIC_BASE=
# ASSET_STORAGE=local   # store to ./public/generated instead of data URLs

# Tuning (optional)
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
ANTHROPIC_MODEL=claude-sonnet-4-6
INKWELL_FREE_IMAGE_LIMIT=2

# ════════════════ PHASE 5 — Stripe billing (optional) ════════════════
# TEST-mode keys from dashboard.stripe.com. docs/12-phase5-billing.md.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_CREATOR=
STRIPE_PRICE_PRO=
